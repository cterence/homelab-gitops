{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:best-practices',
    ':timezone(Europe/Paris)',
    ':label(renovate)',
    ':semanticPrefixFix',
    ':separateMultipleMajorReleases',
    ':automergeBranch',
    ':automergeStableNonMajor',
    ':automergeDigest',
    ':skipStatusChecks',
  ],
  dependencyDashboardTitle: '🤖 Renovate Dashboard',
  commitMessageTopic: '{{depName}}',
  commitMessageExtra: 'to {{newVersion}}',
  commitMessageSuffix: '',
  ignorePaths: [],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)Chart\\.yaml$/',
      ],
      matchStrings: [
        'repository: git\\+https://github.com/(?<packageName>[^@\\s]+)@(?:[^?\\s]+)\\?ref=(?<currentValue>[^\\s]+)\\s+version: (?<currentVersion>[^\\s]+)',
      ],
      datasourceTemplate: 'github-tags',
    },
  ],
  packageRules: [
    {
      matchManagers: [
        'helmv3',
      ],
      matchPackageNames: [
        'local-path-provisioner',
      ],
      enabled: false,
    },
    {
      matchPackageNames: [
        'velero/velero-plugin-for-aws', // FIXME: https://github.com/velero-io/velero/issues/9951
      ],
      enabled: false,
    },
    {
      matchDatasources: [
        'helm',
      ],
      commitMessageTopic: 'chart {{depName}}',
    },
    {
      matchDatasources: [
        'docker',
      ],
      commitMessageTopic: 'image {{depName}}',
    },
    {
      versioning: 'regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<revision>\\d+)-ls(?<build>\\d+)$',
      matchPackageNames: [
        '/^lscr.io\\/linuxserver\\//',
      ],
    },
    {
      versioning: 'regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-ls(?<build>\\d+)$',
      matchPackageNames: [
        '/^lscr.io\\/linuxserver\\/bazarr/',
      ],
    },
    {
      versioning: 'regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?<compatibility>ubu\\d+)-ls(?<build>\\d+)$',
      matchPackageNames: [
        '/^lscr.io\\/linuxserver\\/jellyfin/',
      ],
    },
    {
      versioning: 'regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<compatibility>r\\d)-ls(?<build>\\d+)$',
      matchPackageNames: [
        '/^lscr.io\\/linuxserver\\/qbittorrent/',
      ],
    },
    {
      matchPackageNames: [
        'garage',
      ],
      matchDatasources: [
        'helm',
      ],
      overrideDatasource: 'custom.garage',
      registryUrls: [
        'https://git.deuxfleurs.fr/Deuxfleurs/garage/raw/branch/main/script/helm/garage/Chart.yaml',
      ],
    },
    {
      matchPackageNames: [
        '/ghcr.io\\/dgtlmoon\\/changedetection.io/',
        '/otel\\/opentelemetry-collector-contrib/',
        '/opentelemetry-operator/',
        '/opentelemetry-collector/',
        '/ghcr.io\\/gtsteffaniak\\/filebrowser/',
        '/qtap/',
        'mendhak/http-https-echo',
        'slskd/slskd',
        '/valkey/',
      ],
      automerge: true,
    },
  ],
  customDatasources: {
    garage: {
      format: 'yaml',
      transformTemplates: [
        '{"releases":[{"version": $.version}]}',
      ],
    },
  },
}
